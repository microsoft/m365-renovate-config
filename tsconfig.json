{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "module": "NodeNext",
    "target": "esnext",
    "lib": ["ES2024"],
    "rewriteRelativeImportExtensions": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,
    "types": ["node"]
  },
  "include": ["scripts"],
  "exclude": ["node_modules"]
}
